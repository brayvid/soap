  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tensorflow/tfjs-node": "^4.22.0",
    "compression": "^1.8.0",
    "d3": "^7.9.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "knex": "^3.1.0",
    "pg": "^8.14.1",
    "socket.io": "^4.8.1",
    "vader-sentiment": "^1.1.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "vite": "^5.4.2"
  }
